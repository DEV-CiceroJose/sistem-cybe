generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enums no Prisma; usamos String com valores controlados na aplicação.
// status: PENDENTE | EM_ANDAMENTO | CONCLUIDA | ERRO
// classificacao: EXCELENTE | BOA | ATENCAO | CRITICA
model Auditoria {
  id            String   @id @default(uuid())
  url           String
  status        String   @default("PENDENTE")
  score         Int?
  classificacao String?
  erro          String?
  criadoEm      DateTime @default(now())
  concluidoEm   DateTime?

  resultado     Resultado?
  relatorio     Relatorio?

  @@index([url])
  @@index([criadoEm])
}

model Resultado {
  id            String   @id @default(uuid())
  auditoriaId   String   @unique
  auditoria     Auditoria @relation(fields: [auditoriaId], references: [id], onDelete: Cascade)

  https           String
  headers         String
  cookies         String
  exposicao       String
  tecnologias     String
  performance     String
  scoreDetalhe    String
  vulnerabilidades String @default("[]")
  cors            String @default("{\"accessControlAllowOrigin\":null,\"accessControlAllowCredentials\":false}")
  dns             String @default("{\"a\":[],\"aaaa\":[],\"mx\":[],\"txt\":[],\"ns\":[],\"cname\":[],\"email\":{\"spf\":{\"presente\":false,\"registro\":null},\"dkim\":{\"selectoresEncontrados\":[]},\"dmarc\":{\"presente\":false,\"politica\":null,\"registro\":null}}}")

  criadoEm      DateTime @default(now())
}

model Relatorio {
  id              String   @id @default(uuid())
  auditoriaId     String   @unique
  auditoria       Auditoria @relation(fields: [auditoriaId], references: [id], onDelete: Cascade)
  caminhoArquivo  String
  conteudoMarkdown String
  criadoEm        DateTime @default(now())
}

model Configuracao {
  id           String   @id @default(uuid())
  chave        String   @unique
  valor        String
  atualizadoEm DateTime @updatedAt
}

// frequencia: DIARIA | SEMANAL | MENSAL
model Agendamento {
  id              String    @id @default(uuid())
  url             String
  frequencia      String
  ativo           Boolean   @default(true)
  ultimaExecucao  DateTime?
  proximaExecucao DateTime
  criadoEm        DateTime  @default(now())

  @@index([ativo])
}

// tipo: NOVO_ACHADO | QUEDA_SCORE | QUEDA_CONFORMIDADE
model Alerta {
  id          String   @id @default(uuid())
  url         String
  tipo        String
  mensagem    String
  lido        Boolean  @default(false)
  auditoriaId String?
  criadoEm    DateTime @default(now())

  @@index([lido])
  @@index([criadoEm])
}

model RequestLog {
  id        String   @id @default(uuid())
  metodo    String
  caminho   String
  status    Int
  duracaoMs Int
  criadoEm  DateTime @default(now())

  @@index([criadoEm])
}

model Webhook {
  id       String   @id @default(uuid())
  url      String
  secret   String
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  @@index([ativo])
}

// status: SUCESSO | FALHA
model WebhookEntrega {
  id          String   @id @default(uuid())
  webhookId   String
  auditoriaId String?
  status      String
  httpStatus  Int?
  tentativas  Int      @default(1)
  erro        String?
  criadoEm    DateTime @default(now())

  @@index([webhookId])
  @@index([criadoEm])
}
